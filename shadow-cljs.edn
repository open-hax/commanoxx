{:source-paths ["src"]

 :nrepl {:port 7888}

 :http {:port 9635}        ; <-- shadow-cljs dashboard, pinned away from 9630

 :dev-http {8091 "public"}

 :js-options
 {:js-package-dirs ["node_modules" "node_modules/.pnpm"]}

 :dependencies
 [[lilactown/helix "0.2.2"]]

 :builds
 {:app
  {:target :browser
   :output-dir "public/js"
   :modules {:index {:init-fn control-plane.ui.core/mount!}}
